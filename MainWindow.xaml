<Window x:Class="InchirieriMasiniWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sistem Inchirieri Masini" Height="600" Width="900"
        Background="#F0F4F8">

    <Window.Resources>
        
        <Style x:Key="BtnStyle" TargetType="Button">
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        
        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="White" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="4,0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        
        <Style x:Key="ComboStyle" TargetType="ComboBox">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="34"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        
        <Border Grid.Row="0" Background="#2563EB" CornerRadius="10" Padding="20,14" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="🚗" FontSize="28" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <StackPanel>
                        <TextBlock Text="Sistem Închirieri Mașini" FontSize="22" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Gestiune Flotă, Clienți &amp; Închirieri" FontSize="12" Foreground="#BFDBFE"/>
                    </StackPanel>
                </StackPanel>

                
                <Button Grid.Column="1" Content="🔑 Închiriere Nouă" Click="BtnInchiriereNoua_Click"
                        Background="#10B981" Foreground="White" FontWeight="Bold"
                        Padding="16,8" Cursor="Hand" VerticalAlignment="Center">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#059669"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        
        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">
            <TabControl.Resources>
                
                <Style TargetType="TabItem">
                    <Setter Property="HeaderTemplate">
                        <Setter.Value>
                            <DataTemplate>
                                <ContentPresenter Content="{TemplateBinding Content}" Margin="12,6"/>
                            </DataTemplate>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#64748B"/>
                    <Setter Property="BorderThickness" Value="0,0,0,3"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="Border" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" Margin="0,0,14,6">
                                    <ContentPresenter x:Name="ContentSite" ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Foreground" Value="#2563EB"/>
                                        <Setter Property="BorderBrush" Value="#2563EB"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="#1D4ED8"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            
            <TabItem Header="🚗 Gestiune Flotă (Mașini)">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    
                    <Border Grid.Row="0" Background="White" CornerRadius="10" Padding="16" Margin="0,0,0,16">
                        <Border.Effect>
                            <DropShadowEffect Color="#CBD5E1" BlurRadius="8" ShadowDepth="2" Opacity="0.4"/>
                        </Border.Effect>
                        <StackPanel>
                            <TextBlock Text="Adaugă Mașină Nouă" FontSize="15" FontWeight="Bold" 
                                       Foreground="#1E3A5F" Margin="0,0,0,12"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="Marcă" FontSize="11" Foreground="#64748B" Margin="0,0,0,4"/>
                                    <TextBox x:Name="TxtMarca" Style="{StaticResource InputStyle}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                    <TextBlock Text="Model" FontSize="11" Foreground="#64748B" Margin="0,0,0,4"/>
                                    <TextBox x:Name="TxtModel" Style="{StaticResource InputStyle}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Margin="0,0,8,0">
                                    <TextBlock Text="Nr. Înmatriculare" FontSize="11" Foreground="#64748B" Margin="0,0,0,4"/>
                                    <TextBox x:Name="TxtNr" Style="{StaticResource InputStyle}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="3" Margin="0,0,8,0">
                                    <TextBlock Text="Culoare" FontSize="11" Foreground="#64748B" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="CmbCuloare" Style="{StaticResource ComboStyle}">
                                        <ComboBoxItem Content="Rosu"/>
                                        <ComboBoxItem Content="Alb"/>
                                        <ComboBoxItem Content="Negru"/>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Grid.Column="4" Margin="0,0,8,0">
                                    <TextBlock Text="Opțiuni" FontSize="11" Foreground="#64748B" Margin="0,0,0,4"/>
                                    <StackPanel Orientation="Vertical">
                                        <CheckBox x:Name="ChkAer" Content="Aer Cond." FontSize="11"/>
                                        <CheckBox x:Name="ChkNav" Content="Navigatie" FontSize="11"/>
                                        <CheckBox x:Name="ChkCutie" Content="Cutie Auto" FontSize="11"/>
                                    </StackPanel>
                                </StackPanel>

                                <Button Grid.Column="5" Content="➕ Adaugă" Style="{StaticResource BtnStyle}"
                                        VerticalAlignment="Bottom" Click="BtnAdauga_Click"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    
                    <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="16">
                        <Border.Effect>
                            <DropShadowEffect Color="#CBD5E1" BlurRadius="8" ShadowDepth="2" Opacity="0.4"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Lista Mașini" FontSize="15" FontWeight="Bold" 
                                           Foreground="#1E3A5F" VerticalAlignment="Center"/>
                                <TextBox x:Name="TxtCautare" Grid.Column="1" Style="{StaticResource InputStyle}"
                                         Width="200" Margin="0,0,8,0"
                                         TextChanged="TxtCautare_TextChanged"/>
                                <Button Grid.Column="2" Content="🔍 Caută după marcă" 
                                        Style="{StaticResource BtnStyle}" Click="BtnCauta_Click"/>
                            </Grid>

                            <DataGrid Grid.Row="1" x:Name="GridMasini"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      GridLinesVisibility="Horizontal"
                                      HeadersVisibility="Column"
                                      BorderThickness="0"
                                      RowBackground="White"
                                      AlternatingRowBackground="#F8FAFC"
                                      FontSize="13">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Marcă" Binding="{Binding Marca}" Width="*"/>
                                    <DataGridTextColumn Header="Model" Binding="{Binding Model}" Width="*"/>
                                    <DataGridTextColumn Header="Nr. Înmatriculare" Binding="{Binding NumarInmatriculare}" Width="*"/>
                                    <DataGridTextColumn Header="Culoare" Binding="{Binding CuloareMasina}" Width="*"/>
                                    <DataGridTextColumn Header="Opțiuni" Binding="{Binding OptiuniMasina}" Width="2*"/>
                                    <DataGridTemplateColumn Header="Disponibil" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding DisponibilText}" 
                                                           Foreground="{Binding DisponibilCuloare}"
                                                           FontWeight="Bold" HorizontalAlignment="Center"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="Acțiuni" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="🗑 Șterge" Click="BtnSterge_Click"
                                                        Background="#EF4444" Foreground="White"
                                                        BorderThickness="0" Padding="6,3" Cursor="Hand"
                                                        Tag="{Binding NumarInmatriculare}">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" 
                                                                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            
            <TabItem Header="👥 Gestiune Clienți">
                <Grid Margin="0,10,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    
                    <Border Grid.Row="0" Background="White" CornerRadius="10" Padding="16" Margin="0,0,0,16">
                        <Border.Effect>
                            <DropShadowEffect Color="#CBD5E1" BlurRadius="8" ShadowDepth="2" Opacity="0.4"/>
                        </Border.Effect>
                        <StackPanel>
                            
                            <TextBlock Text="{Binding ElementName=GridClienti, Path=SelectedItem.NumeComplet, StringFormat='✍️ Editare Client: {0}', TargetNullValue='👥 Adaugă Client Nou'}" 
                                       FontSize="15" FontWeight="Bold" 
                                       Foreground="#1E3A5F" Margin="0,0,0,12"/>
                            
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="CNP (unic)" FontSize="11" Foreground="#64748B" Margin="0,0,0,4"/>
                                    <TextBox x:Name="TxtCnp" Style="{StaticResource InputStyle}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                    <TextBlock Text="Nume" FontSize="11" Foreground="#64748B" Margin="0,0,0,4"/>
                                    <TextBox x:Name="TxtNumeClient" Style="{StaticResource InputStyle}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Margin="0,0,8,0">
                                    <TextBlock Text="Prenume" FontSize="11" Foreground="#64748B" Margin="0,0,0,4"/>
                                    <TextBox x:Name="TxtPrenumeClient" Style="{StaticResource InputStyle}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="3" Margin="0,0,8,0">
                                    <TextBlock Text="Telefon" FontSize="11" Foreground="#64748B" Margin="0,0,0,4"/>
                                    <TextBox x:Name="TxtTelefon" Style="{StaticResource InputStyle}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="4" Margin="0,0,8,0">
                                    <TextBlock Text="Nr. Permis" FontSize="11" Foreground="#64748B" Margin="0,0,0,4"/>
                                    <TextBox x:Name="TxtPermis" Style="{StaticResource InputStyle}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Bottom">
                                    <Button x:Name="BtnAdaugaClient" Content="➕ Adaugă" Style="{StaticResource BtnStyle}"
                                            Click="BtnAdaugaClient_Click" Margin="0,0,4,0"/>
                                    <Button x:Name="BtnModificaClient" Content="💾 Salvează" Style="{StaticResource BtnStyle}"
                                            Background="#F59E0B" Click="BtnModificaClient_Click" IsEnabled="False" Margin="0,0,4,0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#D97706"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter Property="Background" Value="#E2E8F0"/>
                                                        <Setter Property="Foreground" Value="#94A3B8"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <Button Content="🔄 Reset" Style="{StaticResource BtnStyle}"
                                            Background="#64748B" Click="BtnReseteazaClient_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#475569"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    
                    <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="16">
                        <Border.Effect>
                            <DropShadowEffect Color="#CBD5E1" BlurRadius="8" ShadowDepth="2" Opacity="0.4"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Lista Clienți Înregistrați" FontSize="15" FontWeight="Bold" 
                                           Foreground="#1E3A5F" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <TextBlock Text="🔍 Căutare:" FontSize="13" Foreground="#64748B" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBox x:Name="TxtCautareClient" Style="{StaticResource InputStyle}"
                                             Width="220" TextChanged="TxtCautareClient_TextChanged"/>
                                </StackPanel>
                            </Grid>

                            <DataGrid Grid.Row="1" x:Name="GridClienti"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      GridLinesVisibility="Horizontal"
                                      HeadersVisibility="Column"
                                      BorderThickness="0"
                                      RowBackground="White"
                                      AlternatingRowBackground="#F8FAFC"
                                      FontSize="13"
                                      SelectionChanged="GridClienti_SelectionChanged">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="CNP" Binding="{Binding CNP}" Width="1.2*"/>
                                    <DataGridTextColumn Header="Nume" Binding="{Binding Nume}" Width="*"/>
                                    <DataGridTextColumn Header="Prenume" Binding="{Binding Prenume}" Width="*"/>
                                    <DataGridTextColumn Header="Telefon" Binding="{Binding Telefon}" Width="*"/>
                                    <DataGridTextColumn Header="Permis Conducere" Binding="{Binding PermisConducere}" Width="1.2*"/>
                                    <DataGridTemplateColumn Header="Acțiuni" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="🗑 Șterge" Click="BtnStergeClient_Click"
                                                        Background="#EF4444" Foreground="White"
                                                        BorderThickness="0" Padding="6,3" Cursor="Hand"
                                                        Tag="{Binding CNP}">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" 
                                                                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        
        <Border Grid.Row="2" Background="#E2E8F0" CornerRadius="6" Padding="12,6" Margin="0,12,0,0">
            <TextBlock x:Name="TxtStatus" Text="Gata." FontSize="12" Foreground="#475569"/>
        </Border>
    </Grid>
</Window>